# Скопируй этот файл как .env.production и заполни своими URL'ами

# URL админ-панели (куда переходить из портала)
VITE_ADMIN_URL=https://admin.welcome24.ru

# URL портала агента (нужен для админки и для самого портала)
VITE_PORTAL_URL=https://app.welcome24.ru

# Эндпоинт бэкенда (появится когда сделаем бэк)
VITE_API_URL=https://api.welcome24.ru
